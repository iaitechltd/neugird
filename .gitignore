# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local store snapshot — holds live data incl. working agent-gateway keys; never public
.neugrid-store.json

# scratchpad — throwaway test harnesses + store backups (the backups copy the store's live keys); never public
/scratchpad/

# stray design-export assets
Group 3/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Echo Studio engine workdirs (re-materialized from the store)
.studio-workspaces/
.agent-workspaces/
